# .env — local deployment configuration (gitignored, never committed)
# Copy this file to .env and fill in your values.

# Path to mounted USB stick for 'make usb' target.
# This should be the directory where .tap files will be copied.
# The directory must exist (USB must be mounted) when running make usb.
# Example:
# USBPATH = /media/xahmol/USBSTICK/oric
USBPATH = /media/yourname/USBSTICK/oric
